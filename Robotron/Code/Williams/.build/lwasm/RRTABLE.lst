E2E7 20B8             (m/src/RRTABLE.ASM):00428                BRA    COMMM 
                      (m/src/RRTABLE.ASM):00429         
E2E9 8EE2D8           (m/src/RRTABLE.ASM):00430         COLC   LDX    #CCTAB+7
E2EC 108E980C         (m/src/RRTABLE.ASM):00431                LDY    #PCRAM+$C
E2F0 CCE2D1           (m/src/RRTABLE.ASM):00432         COLLL  LDD    #CCTAB
E2F3 20AF             (m/src/RRTABLE.ASM):00433                BRA    COLENT
                      (m/src/RRTABLE.ASM):00434         
E2F5 8EE2D1           (m/src/RRTABLE.ASM):00435         COLD   LDX    #CCTAB  
E2F8 108E980D         (m/src/RRTABLE.ASM):00436                LDY    #PCRAM+$D
E2FC 20F2             (m/src/RRTABLE.ASM):00437                BRA    COLLL 
                      (m/src/RRTABLE.ASM):00438         
E2FE 372F271F17474787 (m/src/RRTABLE.ASM):00439         COLTAB FCB    $37,$2F,$27,$1F,$17,$47,$47,$87
E306 87C7C7C6C5CCCBCA (m/src/RRTABLE.ASM):00440                FCB    $87,$C7,$C7,$C6,$C5,$CC,$CB,$CA
E30E C0D0983833       (m/src/RRTABLE.ASM):00441                FCB    $C0,$D0,$98,$38,$33
     E313             (m/src/RRTABLE.ASM):00442         TABEDD EQU    *
                      (m/src/RRTABLE.ASM):00443         
     0007             (m/src/RRTABLE.ASM):00444         UPPER  EQU    PD
     0008             (m/src/RRTABLE.ASM):00445         LOWER  EQU    PD+1
     0009             (m/src/RRTABLE.ASM):00446         LEFT   EQU    PD+2
     000A             (m/src/RRTABLE.ASM):00447         RIGHT  EQU    PD+3
     000B             (m/src/RRTABLE.ASM):00448         HFLAV  EQU    PD+4
     000C             (m/src/RRTABLE.ASM):00449         LFLAV  EQU    PD+5
                      (m/src/RRTABLE.ASM):00450         
                      (m/src/RRTABLE.ASM):00451         *      MARQ - DRAW A LINKY MARQUIS.  PASS UPPER LEFT IN X.
                      (m/src/RRTABLE.ASM):00452         *      PASS LOWER RIGHT IN Y.  
                      (m/src/RRTABLE.ASM):00453         *      RANGES ARE INCLUSIVE.  LOWER-UPPER MUST BE EVEN (ODD INCLUSIVE)
                      (m/src/RRTABLE.ASM):00454         *      A CONTAINS THE HIGH AND LOW FLAVOR COLORS (<OUTER><INNER>)
                      (m/src/RRTABLE.ASM):00455         
E313 3436             (m/src/RRTABLE.ASM):00456         MARQ   PSHS   X,Y,D  
E315 DE15             (m/src/RRTABLE.ASM):00457                LDU    CRPROC
E317 84F0             (m/src/RRTABLE.ASM):00458                ANDA   #$F0
E319 A74B             (m/src/RRTABLE.ASM):00459                STA    HFLAV,U  SAVE FLAVOR COLORS
E31B A6E4             (m/src/RRTABLE.ASM):00460                LDA    ,S
E31D 840F             (m/src/RRTABLE.ASM):00461                ANDA   #$0F
E31F A74C             (m/src/RRTABLE.ASM):00462                STA    LFLAV,U
E321 1F10             (m/src/RRTABLE.ASM):00463                TFR    X,D
E323 A749             (m/src/RRTABLE.ASM):00464                STA    LEFT,U
E325 E747             (m/src/RRTABLE.ASM):00465                STB    UPPER,U
E327 1F20             (m/src/RRTABLE.ASM):00466                TFR    Y,D
E329 A74A             (m/src/RRTABLE.ASM):00467                STA    RIGHT,U
E32B E748             (m/src/RRTABLE.ASM):00468                STB    LOWER,U
E32D E047             (m/src/RRTABLE.ASM):00469                SUBB   UPPER,U        LOWER-UPPER ODD???
E32F 56               (m/src/RRTABLE.ASM):00470                RORB                  CHECK
E330 2402             (m/src/RRTABLE.ASM):00471                BCC    MARQ1          NOPE
E332 6A48             (m/src/RRTABLE.ASM):00472                DEC    LOWER,U        NOT THAT LOW...OK?
                      (m/src/RRTABLE.ASM):00473         
E334 A647             (m/src/RRTABLE.ASM):00474         MARQ1  LDA    UPPER,U        DO TOP LINE
E336 8D3B             (m/src/RRTABLE.ASM):00475                BSR    HHIGH          HIGH PART OF TOP HORIZONTAL LINE
E338 4C               (m/src/RRTABLE.ASM):00476                INCA
E339 8D4A             (m/src/RRTABLE.ASM):00477                BSR    HLOW           LOW PART
                      (m/src/RRTABLE.ASM):00478         *
E33B A648             (m/src/RRTABLE.ASM):00479                LDA    LOWER,U
E33D 8D34             (m/src/RRTABLE.ASM):00480                BSR    HHIGH          1 LESS FOR GEN PURP
E33F 4A               (m/src/RRTABLE.ASM):00481                DECA
E340 8D43             (m/src/RRTABLE.ASM):00482                BSR    HLOW
                      (m/src/RRTABLE.ASM):00483         *
E342 A649             (m/src/RRTABLE.ASM):00484                LDA    LEFT,U         LEFT BYTE
E344 8D0B             (m/src/RRTABLE.ASM):00485                BSR    VHIGH          HIGH FLAVOR STUFF IN A VERT LINE
E346 8D17             (m/src/RRTABLE.ASM):00486                BSR    VLOW           LOW FLAVOR STUFF IN A VERT LINE
                      (m/src/RRTABLE.ASM):00487         *
E348 A64A             (m/src/RRTABLE.ASM):00488                LDA    RIGHT,U
E34A 8D05             (m/src/RRTABLE.ASM):00489                BSR    VHIGH
E34C 4A               (m/src/RRTABLE.ASM):00490                DECA
E34D 8D10             (m/src/RRTABLE.ASM):00491                BSR    VLOW
E34F 35B6             (m/src/RRTABLE.ASM):00492                PULS   D,X,Y,PC
                      (m/src/RRTABLE.ASM):00493         
                      (m/src/RRTABLE.ASM):00494         *      VHIGH - PLOT VERTICAL LINE FROM [UPPER TO LOWER]
                      (m/src/RRTABLE.ASM):00495         *      CONSISTING OF EVERY OTHER BYTE GETTING THE HIGH NIBBLE COLOR
                      (m/src/RRTABLE.ASM):00496         *      A HAS THE X TO USE
                      (m/src/RRTABLE.ASM):00497         
E351 3416             (m/src/RRTABLE.ASM):00498         VHIGH  PSHS   D,X
E353 8D14             (m/src/RRTABLE.ASM):00499                BSR    SETUPV   SETUP X,B
E355 5C               (m/src/RRTABLE.ASM):00500                INCB            1 MORE TO BE INCLUSIVE
E356 A64B             (m/src/RRTABLE.ASM):00501                LDA    HFLAV,U  GET HIGH FLAVOR
E358 A781             (m/src/RRTABLE.ASM):00502         VHIGH1 STA    ,X++     STORE THE BYTE
E35A 5A               (m/src/RRTABLE.ASM):00503                DECB
E35B 26FB             (m/src/RRTABLE.ASM):00504                BNE    VHIGH1
E35D 3596             (m/src/RRTABLE.ASM):00505                PULS   D,X,PC
                      (m/src/RRTABLE.ASM):00506         
E35F 3416             (m/src/RRTABLE.ASM):00507         VLOW   PSHS   D,X
E361 8D06             (m/src/RRTABLE.ASM):00508                BSR    SETUPV   SETUP X,B
E363 3001             (m/src/RRTABLE.ASM):00509                LEAX   1,X      MOVE X UP 1
E365 A64C             (m/src/RRTABLE.ASM):00510                LDA    LFLAV,U  USE LOW FLAVOR
E367 20EF             (m/src/RRTABLE.ASM):00511                BRA    VHIGH1
                      (m/src/RRTABLE.ASM):00512         
E369 E647             (m/src/RRTABLE.ASM):00513         SETUPV LDB    UPPER,U  GET UPPER Y
E36B 1F01             (m/src/RRTABLE.ASM):00514                TFR    D,X      THIS IS PONTER
E36D E648             (m/src/RRTABLE.ASM):00515                LDB    LOWER,U
E36F E047             (m/src/RRTABLE.ASM):00516                SUBB   UPPER,U  THIS IS GUARANTEED EVEN
E371 54               (m/src/RRTABLE.ASM):00517                LSRB            1/2 PLEASE (EVERY 2 IS PLOTTED)
E372 39               (m/src/RRTABLE.ASM):00518                RTS
                      (m/src/RRTABLE.ASM):00519         
                      (m/src/RRTABLE.ASM):00520         *      HHIGH - THIS ROUTINE PLOTS HIGH COLOR IN THE HIGH HALF OF
                      (m/src/RRTABLE.ASM):00521         *      CONSECUTIVE HORIZONTAL PIXELS GOING FROM 
                      (m/src/RRTABLE.ASM):00522         *      [LEFT TO RIGHT] AT THE HEIGHT GIVEN IN REGISTER A.
                      (m/src/RRTABLE.ASM):00523         
E373 3416             (m/src/RRTABLE.ASM):00524         HHIGH  PSHS   X,D
E375 8D16             (m/src/RRTABLE.ASM):00525                BSR    SETUPH   SETUP COUNT IN B, X POINTS AT FIRST BYTE
E377 5C               (m/src/RRTABLE.ASM):00526                INCB            ADD 1 TO MAKE IT INCLUSIVE
E378 A64B             (m/src/RRTABLE.ASM):00527                LDA    HFLAV,U  GET THE DATA BYTE
E37A A784             (m/src/RRTABLE.ASM):00528         HHIGH1 STA    ,X       STORE 1
E37C 30890100         (m/src/RRTABLE.ASM):00529                LEAX   $100,X   PUSH TO NEXT
E380 5A               (m/src/RRTABLE.ASM):00530                DECB            1 LESS
E381 26F7             (m/src/RRTABLE.ASM):00531                BNE    HHIGH1
E383 3596             (m/src/RRTABLE.ASM):00532                PULS   X,D,PC
                      (m/src/RRTABLE.ASM):00533         
                      (m/src/RRTABLE.ASM):00534         *      HLOW - THIS ROUTINE PLOTS LOW COLOR IN THE LOW HALF OF
                      (m/src/RRTABLE.ASM):00535         *      CONSECUTIVE HORIZONTAL PIXELS GOING FROM
                      (m/src/RRTABLE.ASM):00536         *      [LEFT TO RIGHT) AT THE HEIGHT GIVEN IN REGISTER A.
                      (m/src/RRTABLE.ASM):00537         
E385 3416             (m/src/RRTABLE.ASM):00538         HLOW   PSHS   X,D
E387 8D04             (m/src/RRTABLE.ASM):00539                BSR    SETUPH
E389 A64C             (m/src/RRTABLE.ASM):00540                LDA    LFLAV,U  USE LOW FLAVOR
E38B 20ED             (m/src/RRTABLE.ASM):00541                BRA    HHIGH1   AND DO NORMAL PROCESSING ABOVE 
                      (m/src/RRTABLE.ASM):00542         
E38D 1F89             (m/src/RRTABLE.ASM):00543         SETUPH TFR    A,B      MOVE Y OVER
E38F A649             (m/src/RRTABLE.ASM):00544                LDA    LEFT,U   GET LEFT X
E391 1F01             (m/src/RRTABLE.ASM):00545                TFR    D,X      MAKE POINTER
E393 E64A             (m/src/RRTABLE.ASM):00546                LDB    RIGHT,U
E395 E049             (m/src/RRTABLE.ASM):00547                SUBB   LEFT,U   FIND DIFFERENCE (EXCLUSIVE
E397 39               (m/src/RRTABLE.ASM):00548                RTS             AND RETURN
                      (m/src/RRTABLE.ASM):00549         
                      (m/src/RRTABLE.ASM):00550                END
