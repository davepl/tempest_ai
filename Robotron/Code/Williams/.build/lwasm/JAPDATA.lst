                      (m/src/JAPDATA.ASM):00001         *
                      (m/src/JAPDATA.ASM):00002         *      ROBOTRON 3-10-82 RELEASE 1
                      (m/src/JAPDATA.ASM):00003         *
                      (m/src/JAPDATA.ASM):00004         
                      (m/src/JAPDATA.ASM):00005                ORG    $26B7
26B7 65               (m/src/JAPDATA.ASM):00006                FCB    $65
                      (m/src/JAPDATA.ASM):00007                ORG    $5E77
5E77 68               (m/src/JAPDATA.ASM):00008                FCB    $68
                      (m/src/JAPDATA.ASM):00009                ORG    $DE54
DE54 1B1B1B1B1B1B1B1B (m/src/JAPDATA.ASM):00010                FCB    $1B,$1B,$1B,$1B,$1B,$1B,$1B,$1B
                      (m/src/JAPDATA.ASM):00011         *
                      (m/src/JAPDATA.ASM):00012         *      CHECKSUMS
                      (m/src/JAPDATA.ASM):00013         *
                      (m/src/JAPDATA.ASM):00014         *
                      (m/src/JAPDATA.ASM):00015         *      0-$4D
                      (m/src/JAPDATA.ASM):00016         *      1-$19
                      (m/src/JAPDATA.ASM):00017         *      2-$D9
                      (m/src/JAPDATA.ASM):00018         *      3-$1B
                      (m/src/JAPDATA.ASM):00019         *      4-$7E
                      (m/src/JAPDATA.ASM):00020         *      5-$DD
                      (m/src/JAPDATA.ASM):00021         *      6-$F1
                      (m/src/JAPDATA.ASM):00022         *      7-$3E
                      (m/src/JAPDATA.ASM):00023         *      8-$6D
                      (m/src/JAPDATA.ASM):00024         *
                      (m/src/JAPDATA.ASM):00025         *      D-$4D
                      (m/src/JAPDATA.ASM):00026         *      E-$48
                      (m/src/JAPDATA.ASM):00027         
                      (m/src/JAPDATA.ASM):00028         *      SUPER CHECKERS - 98F3 = $37
                      (m/src/JAPDATA.ASM):00029         *                       BE72 = $4A
                      (m/src/JAPDATA.ASM):00030         
                      (m/src/JAPDATA.ASM):00031         
                      (m/src/JAPDATA.ASM):00032         **************************************************************************
                      (m/src/JAPDATA.ASM):00033         *                                                                        *
                      (m/src/JAPDATA.ASM):00034         *          Here is a detailed explaination of the Robotron 2084          *
                      (m/src/JAPDATA.ASM):00035         *          "JAP ZAPPERS".  This was a primitive system setup to          *
                      (m/src/JAPDATA.ASM):00036         *          try and make it more difficult for game copiers to            *
                      (m/src/JAPDATA.ASM):00037         *          Modify the game.  There were scrambled sections of the        *
                      (m/src/JAPDATA.ASM):00038         *          code that would try and monitor "random" checksums            *
                      (m/src/JAPDATA.ASM):00039         *          of regions of the code.  If they detected that the code       *
                      (m/src/JAPDATA.ASM):00040         *          had been modified, they would cause random program            *
                      (m/src/JAPDATA.ASM):00041         *          events to occur at a low frequency (the random and            *
                      (m/src/JAPDATA.ASM):00042         *          low frequency combination would make it harder to track       *
                      (m/src/JAPDATA.ASM):00043         *          down the culprits).  We always assumed that developers        *
                      (m/src/JAPDATA.ASM):00044         *          with good tools would find these quickly, but Christian       *
                      (m/src/JAPDATA.ASM):00045         *          Gingras, removed this small nuisance while trying to          *
                      (m/src/JAPDATA.ASM):00046         *          fix the other bugs he had found in the program (with          *
                      (m/src/JAPDATA.ASM):00047         *          the aid of his Radio Shack Color Computer).                   *
                      (m/src/JAPDATA.ASM):00048         *                                                                        *
                      (m/src/JAPDATA.ASM):00049         *          There are 2 regions for which checksums are kept.  The        *
                      (m/src/JAPDATA.ASM):00050         *          checksums are not the sum of all bytes, but the sum           *
                      (m/src/JAPDATA.ASM):00051         *          of every 8 and 16 bytes respectively.  The first checksum     *
                      (m/src/JAPDATA.ASM):00052         *          is the sum of every 16th byte from $0007 to $8927 inclusive   *
                      (m/src/JAPDATA.ASM):00053         *          and is stored at $98F3 (HCK1).  This sum should come out to   *
                      (m/src/JAPDATA.ASM):00054         *          $37.  The second checksum is the sum of every 8th byte        *
                      (m/src/JAPDATA.ASM):00055         *          from $D015 to $EAAD and is stored at $BE72 (HCK2).  This sum  *
                      (m/src/JAPDATA.ASM):00056         *          should come out to $4A.                                       *
                      (m/src/JAPDATA.ASM):00057         *                                                                        *
                      (m/src/JAPDATA.ASM):00058         *          There are 6 places in the software that are concerned         *
                      (m/src/JAPDATA.ASM):00059         *          with the checksums.                                           *
                      (m/src/JAPDATA.ASM):00060         *                                                                        *
                      (m/src/JAPDATA.ASM):00061         *          In RRTEXT, at label WORDZ (the call for message handling)     *
                      (m/src/JAPDATA.ASM):00062         *          there is a check of HCK1 for its $37 value, and handling      *
                      (m/src/JAPDATA.ASM):00063         *          to zap if incorrect.                                          *
                      (m/src/JAPDATA.ASM):00064         *                                                                        *
                      (m/src/JAPDATA.ASM):00065         *          In RRS22, the code to set the HCK1 value (by performing the   *
                      (m/src/JAPDATA.ASM):00066         *          required addition) is found within the PINIT routine.         *
                      (m/src/JAPDATA.ASM):00067         *          PINIT is used to initialize the process structure at the      *
                      (m/src/JAPDATA.ASM):00068         *          start of each turn.                                           *
                      (m/src/JAPDATA.ASM):00069         *                                                                        *
                      (m/src/JAPDATA.ASM):00070         *          In RRS22 there is a check of HCK1 for its $37 value in the    *
                      (m/src/JAPDATA.ASM):00071         *          ASCAN routine.  ASCAN is called at the start of each wave     *
                      (m/src/JAPDATA.ASM):00072         *          by each object to make sure the space it wants is un-occupied *
                      (m/src/JAPDATA.ASM):00073         *                                                                        *
                      (m/src/JAPDATA.ASM):00074         *          In RRG23 the code to setup the HCK2 value (by performing      *
                      (m/src/JAPDATA.ASM):00075         *          the required addition) is found within the game start         *
                      (m/src/JAPDATA.ASM):00076         *          routine (START1 and START2).                                  *
                      (m/src/JAPDATA.ASM):00077         *                                                                        *
                      (m/src/JAPDATA.ASM):00078         *          In RRX7 there is a check of HCK2 for its $4A value in         *
                      (m/src/JAPDATA.ASM):00079         *          the explosion starter (EXSTV).                                *
                      (m/src/JAPDATA.ASM):00080         *                                                                        *
                      (m/src/JAPDATA.ASM):00081         *          In RRB10 there is a routine that computes the HCK2 value      *
                      (m/src/JAPDATA.ASM):00082         *          (on the fly in case the copiers goose the values into         *
                      (m/src/JAPDATA.ASM):00083         *          ram) and zaps if it does not come up with the $4A value.      *
                      (m/src/JAPDATA.ASM):00084         *          This is found in the brain starter (BRNSTV) and is run        *
                      (m/src/JAPDATA.ASM):00085         *          in any waves that contain BRAIN robots.                       *
                      (m/src/JAPDATA.ASM):00086         *                                                                        *
                      (m/src/JAPDATA.ASM):00087         *          The checksums are computed with the equivilents of the        *
                      (m/src/JAPDATA.ASM):00088         *          following code:                                               *
                      (m/src/JAPDATA.ASM):00089         *                                                                        *
                      (m/src/JAPDATA.ASM):00090         *                            HCK1 ($98F3) = $37                          *
                      (m/src/JAPDATA.ASM):00091         *                                                                        *
                      (m/src/JAPDATA.ASM):00092         *                                  clra                                  *
                      (m/src/JAPDATA.ASM):00093         *                                  ldx     #$0007                        *
                      (m/src/JAPDATA.ASM):00094         *                          loop:   adda    0,x                           *
                      (m/src/JAPDATA.ASM):00095         *                                  leax    $10,x                         *
                      (m/src/JAPDATA.ASM):00096         *                                  cmpx    #$8935                        *
                      (m/src/JAPDATA.ASM):00097         *                                  blo     loop                          *
                      (m/src/JAPDATA.ASM):00098         *                                  sta     hck1                          *
                      (m/src/JAPDATA.ASM):00099         *                                                                        *
                      (m/src/JAPDATA.ASM):00100         *                                                                        *
                      (m/src/JAPDATA.ASM):00101         *                            HCK2 ($BE72) = $4A                          *
                      (m/src/JAPDATA.ASM):00102         *                                                                        *
                      (m/src/JAPDATA.ASM):00103         *                                  clra                                  *
                      (m/src/JAPDATA.ASM):00104         *                                  ldx     #$d015                        *
                      (m/src/JAPDATA.ASM):00105         *                          loop:   adda    0,x                           *
                      (m/src/JAPDATA.ASM):00106         *                                  leax    $8,x                          *
                      (m/src/JAPDATA.ASM):00107         *                                  cmpx    #$EAB1                        *
                      (m/src/JAPDATA.ASM):00108         *                                  blo     loop                          *
                      (m/src/JAPDATA.ASM):00109         *                                  sta     hck2                          *
                      (m/src/JAPDATA.ASM):00110         *                                                                        *
                      (m/src/JAPDATA.ASM):00111         *                                                                        *
                      (m/src/JAPDATA.ASM):00112         **************************************************************************
                      (m/src/JAPDATA.ASM):00113         
                      (m/src/JAPDATA.ASM):00114                END
