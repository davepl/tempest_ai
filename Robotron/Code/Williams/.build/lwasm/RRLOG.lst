                      (       RRLOGD.ASM):00001         *      ROBOTRON PART OF LOGO                             
                      (       RRLOGD.ASM):00002         
                      (       RRLOGD.ASM):00003         *      IF SIGN BIT IS ON, THE BYTE IS A KEY BYTE,
                      (       RRLOGD.ASM):00004         *      ELSE IT IS A DATA BYTE.
                      (       RRLOGD.ASM):00005         
                      (       RRLOGD.ASM):00006         *      KEY BYTE:
                      (       RRLOGD.ASM):00007         
                      (       RRLOGD.ASM):00008         *      1 R L C   N N N N
                      (       RRLOGD.ASM):00009         
                      (       RRLOGD.ASM):00010         *      R = REPEAT LAST COLUMN   N N N N   TIMES
                      (       RRLOGD.ASM):00011         *      L = END OF LETTER
                      (       RRLOGD.ASM):00012         *      C = END OF COLUMN
                      (       RRLOGD.ASM):00013         
                      (       RRLOGD.ASM):00014         *      ELSE THE BYTE IS OF THE FORM:
                      (       RRLOGD.ASM):00015         *
                      (       RRLOGD.ASM):00016         *      0 B C D   D D D D 
                      (       RRLOGD.ASM):00017         *
                      (       RRLOGD.ASM):00018         *      BC  00 = ZERO  10 = COLOR 1  01 = COLOR 2   11 = WHO KNOWS?
                      (       RRLOGD.ASM):00019         *      D = NUMBER OF ROWS TO GET THIS
                      (       RRLOGD.ASM):00020         
     00C0             (       RRLOGD.ASM):00021         REPEAT EQU    $C0
     00A0             (       RRLOGD.ASM):00022         ENDLET EQU    $A0
     0090             (       RRLOGD.ASM):00023         ENDCOL EQU    $90
                      (       RRLOGD.ASM):00024         
     0040             (       RRLOGD.ASM):00025         ON     EQU    $40      INDICATE COLOR IS ON
     0020             (       RRLOGD.ASM):00026         ON2    EQU    $20      COLOR 2 ON
                      (       RRLOGD.ASM):00027         
                      (       RRLOGD.ASM):00028         *      LETTER R
                      (       RRLOGD.ASM):00029         *      LETTER R
                      (       RRLOGD.ASM):00030         *      LETTER R
