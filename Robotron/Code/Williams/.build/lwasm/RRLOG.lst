                      (     RRSCRIPT.ASM):00270         *      MNEMONICS
                      (     RRSCRIPT.ASM):00271         
     0001             (     RRSCRIPT.ASM):00272         SETOB  EQU    1        SET OBJECT DESC.  2 BYTE DESC FOLLOWS
     0002             (     RRSCRIPT.ASM):00273         SETIM  EQU    2        SET IMAGE NUMBER  CURRENT IMAGE TO USE  1 B
     0003             (     RRSCRIPT.ASM):00274         MLEFT  EQU    3        MOVE LEFT <1 BYTE> STEPS
     0004             (     RRSCRIPT.ASM):00275         MRIGHT EQU    4        MOVE RIGHT
     0005             (     RRSCRIPT.ASM):00276         MDOWN  EQU    5        MOVE DOWN
     0006             (     RRSCRIPT.ASM):00277         MUP    EQU    6        MOVE UP
     0007             (     RRSCRIPT.ASM):00278         SETPOS EQU    7        SET POSITION TO <1 BYTE X> <1 BYTE Y>
     0008             (     RRSCRIPT.ASM):00279         SETXV  EQU    8        SET X VELOCITY <2 BYTES>
     0009             (     RRSCRIPT.ASM):00280         SETYV  EQU    9        SET Y VELOCITY <2 BYTES>
     000A             (     RRSCRIPT.ASM):00281         CYCLE  EQU    10       CYCLE <N FRAMES EACH>, <M IMAGES OF OBJECT>
     000B             (     RRSCRIPT.ASM):00282         REST   EQU    11       SLEEP N FRAMES
     000C             (     RRSCRIPT.ASM):00283         DIE    EQU    12       KILL THE GUY
     000D             (     RRSCRIPT.ASM):00284         EXP    EQU    13       MAKE GUY EXPLODE, THEN DIE
     000E             (     RRSCRIPT.ASM):00285         JUMP   EQU    14       CONTINUE SCRIPT AT 2 BYTE ADDRESS
     000F             (     RRSCRIPT.ASM):00286         HIB    EQU    15       ERASE AND REMOVE FROM OBJECT LIST
     0010             (     RRSCRIPT.ASM):00287         REBORN EQU    16       BACK ONTO OBJECT LIST
     0011             (     RRSCRIPT.ASM):00288         FORK   EQU    17       START NEW SCRIPT
     0012             (     RRSCRIPT.ASM):00289         LFIRE  EQU    18       FIRE LEFT FROM OBJECT <1 BYTE FRAMES>
     0013             (     RRSCRIPT.ASM):00290         RFIRE  EQU    19       FIRE RIGHT FROM OBJECT <1 BYTE FRAMES>
     0014             (     RRSCRIPT.ASM):00291         LOOPER EQU    20       COUNT, LABEL
     0015             (     RRSCRIPT.ASM):00292         GHOST  EQU    21       CREATE A SCRIPT WITH MY OBJECT POINTER
     0016             (     RRSCRIPT.ASM):00293         SETRP  EQU    22
     0017             (     RRSCRIPT.ASM):00294         GDIE   EQU    23       GHOST DIE (KILL PROCESS, NOT OBJECT)
     0018             (     RRSCRIPT.ASM):00295         INCIM  EQU    24
     0019             (     RRSCRIPT.ASM):00296         MONO   EQU    25
     001A             (     RRSCRIPT.ASM):00297         RPROG  EQU    26
     001B             (     RRSCRIPT.ASM):00298         PDEAD  EQU    27
