                      (       RRLOGD.ASM):00953         *      LETOUT - OUTPUT A LETTER STORED IN LOGO FORMAT
                      (       RRLOGD.ASM):00954         *
                      (       RRLOGD.ASM):00955         *      X = UPPER LEFT TO OUTPUT, RETURNS UPPER LEFT COLUMN FOLLOWING LETTER
                      (       RRLOGD.ASM):00956         *      U = POINTER TO LETTER DATA
                      (       RRLOGD.ASM):00957         *      Y = ROUTINE TO UPDATE COLOR
                      (       RRLOGD.ASM):00958         *      A = COLOR 1, COLOR 2  INITIALLY
                      (       RRLOGD.ASM):00959         *      B = INITIAL FLAVOR,  RETURNS FLAVOR JUST FOLLOWING LETTER
                      (       RRLOGD.ASM):00960         
8D69 3462             (       RRLOGD.ASM):00961         LETOUT PSHS   A,U,Y
8D6B 84F0             (       RRLOGD.ASM):00962                ANDA   #$F0
8D6D 3402             (       RRLOGD.ASM):00963                PSHS   A
8D6F 44               (       RRLOGD.ASM):00964                LSRA
8D70 44               (       RRLOGD.ASM):00965                LSRA
8D71 44               (       RRLOGD.ASM):00966                LSRA
8D72 44               (       RRLOGD.ASM):00967                LSRA
8D73 AAE0             (       RRLOGD.ASM):00968                ORA   ,S+           COLOR 1 FORMED
8D75 97DF             (       RRLOGD.ASM):00969                STA    LOGCOL
8D77 A6E4             (       RRLOGD.ASM):00970                LDA    ,S
8D79 840F             (       RRLOGD.ASM):00971                ANDA   #$0F
8D7B 3402             (       RRLOGD.ASM):00972                PSHS   A
8D7D 48               (       RRLOGD.ASM):00973                ASLA
8D7E 48               (       RRLOGD.ASM):00974                ASLA
8D7F 48               (       RRLOGD.ASM):00975                ASLA
8D80 48               (       RRLOGD.ASM):00976                ASLA
8D81 AAE0             (       RRLOGD.ASM):00977                ORA   ,S+
8D83 97E0             (       RRLOGD.ASM):00978                STA    LOGCL2         COLOR 2 
8D85 8D04             (       RRLOGD.ASM):00979         CAGAIN BSR    DOCOL          DO A COLUMN
8D87 24FC             (       RRLOGD.ASM):00980                BCC    CAGAIN         NOT END OF LETTER...DO ANOTHER
8D89 35E2             (       RRLOGD.ASM):00981                PULS   A,U,Y,PC       AND RETURN
                      (       RRLOGD.ASM):00982         
8D8B A6C4             (       RRLOGD.ASM):00983         DOCOL  LDA    ,U             CHECK FIRST BYTE OF THE COLUMN
8D8D 43               (       RRLOGD.ASM):00984                COMA
8D8E 85C0             (       RRLOGD.ASM):00985                BITA   #$C0           REPEATER??
8D90 2702             (       RRLOGD.ASM):00986                BEQ    DOCOL0         YEP...NO COLUMN SAVE FOR THIS START
8D92 DFE4             (       RRLOGD.ASM):00987                STU    LOGCST         SAVE COLUMN START
8D94 9FDD             (       RRLOGD.ASM):00988         DOCOL0 STX    LOGX           SAVE THE X FOR COLUMN END
8D96 A6C0             (       RRLOGD.ASM):00989         DOCOL2 LDA    ,U+            GET A DATA BYTE
8D98 2A27             (       RRLOGD.ASM):00990                BPL    DOCOL1         ORDINARY BOREDOM
8D9A 8520             (       RRLOGD.ASM):00991                BITA   #$20           END OF LETTER??
8D9C 2703             (       RRLOGD.ASM):00992                BEQ    DOCOL3         NOPE
8D9E 1A01             (       RRLOGD.ASM):00993                SEC
8DA0 39               (       RRLOGD.ASM):00994         DUMRTS RTS                   INDICATE END OF LETTER
8DA1 8510             (       RRLOGD.ASM):00995         DOCOL3 BITA   #$10           END OF COLUMN??
8DA3 2705             (       RRLOGD.ASM):00996                BEQ    DOCOL4         NOPE
                      (       RRLOGD.ASM):00997         
8DA5 8D5B             (       RRLOGD.ASM):00998                BSR    CEND           DO TERMINAL TYPE OF STUFF
8DA7 1CFE             (       RRLOGD.ASM):00999                CLC
8DA9 39               (       RRLOGD.ASM):01000                RTS                   AND RETURN
                      (       RRLOGD.ASM):01001         
8DAA 8540             (       RRLOGD.ASM):01002         DOCOL4 BITA   #$40           MUST BE REPEAT TIME
8DAC 27E8             (       RRLOGD.ASM):01003                BEQ    DOCOL2         INVALID...CONTINUE
8DAE 840F             (       RRLOGD.ASM):01004                ANDA   #$F            GET COUNT
8DB0 97E1             (       RRLOGD.ASM):01005                STA    LOGCNT         SAVE THE COUNT
                      (       RRLOGD.ASM):01006         
8DB2 DFE2             (       RRLOGD.ASM):01007                STU    LOGSAV         SAVE THE POINTER
8DB4 DEE4             (       RRLOGD.ASM):01008         DOCOL5 LDU    LOGCST         GET START OF COLUMN POINTER
8DB6 8DDC             (       RRLOGD.ASM):01009                BSR    DOCOL0         CURSE AGAIN        
8DB8 0AE1             (       RRLOGD.ASM):01010                DEC    LOGCNT         1 LESS
8DBA 26F8             (       RRLOGD.ASM):01011                BNE    DOCOL5         AND DO IT AGAIN
                      (       RRLOGD.ASM):01012         
8DBC DEE2             (       RRLOGD.ASM):01013                LDU    LOGSAV         GET OUR POINTER BACK PLEASE
8DBE 1CFE             (       RRLOGD.ASM):01014                CLC                   CLEAR OUT THE CARRY GUY
8DC0 39               (       RRLOGD.ASM):01015                RTS
                      (       RRLOGD.ASM):01016         
8DC1 8560             (       RRLOGD.ASM):01017         DOCOL1 BITA   #$60           COLOR??
8DC3 2604             (       RRLOGD.ASM):01018                BNE    DCOL6          YEP
                      (       RRLOGD.ASM):01019         
8DC5 3086             (       RRLOGD.ASM):01020                LEAX   A,X            ADD COUNT TO X IS ALL WE NEED TO DO
8DC7 20CD             (       RRLOGD.ASM):01021                BRA    DOCOL2         AND GET NEXT BYTE
                      (       RRLOGD.ASM):01022         
8DC9 3403             (       RRLOGD.ASM):01023         DCOL6  PSHS   CC,A           SAVE
8DCB 841F             (       RRLOGD.ASM):01024                ANDA   #$1F           REMOVE GARBAGE BITS 
8DCD 1A10             (       RRLOGD.ASM):01025                SEI
8DCF BFCA04           (       RRLOGD.ASM):01026                STX    DEST           PLACE
8DD2 3086             (       RRLOGD.ASM):01027                LEAX   A,X            FORM NEW POINTER
8DD4 8804             (       RRLOGD.ASM):01028                EORA   #4             THROW GREG A BONE
8DD6 B7CA07           (       RRLOGD.ASM):01029                STA    HORIZ+1        HEIGHT
8DD9 8605             (       RRLOGD.ASM):01030                LDA    #5
8DDB B7CA06           (       RRLOGD.ASM):01031                STA    HORIZ          1 WIDE
8DDE FDCA02           (       RRLOGD.ASM):01032                STD    ORIG           CONSTANT GARBAGE
8DE1 A661             (       RRLOGD.ASM):01033                LDA    1,S            GET DIRECTIVE BYTE BACK
8DE3 8540             (       RRLOGD.ASM):01034                BITA   #$40
8DE5 2704             (       RRLOGD.ASM):01035                BEQ    COL2U          USE COLOR 2
8DE7 96DF             (       RRLOGD.ASM):01036                LDA    LOGCOL         GET COLOR1
8DE9 2002             (       RRLOGD.ASM):01037                BRA    COL3U
8DEB 96E0             (       RRLOGD.ASM):01038         COL2U  LDA    LOGCL2         USE COLOR 2
8DED B7CA01           (       RRLOGD.ASM):01039         COL3U  STA    CONST
8DF0 8612             (       RRLOGD.ASM):01040                LDA    #$12           CONSTANT STUFF ETC, BUT....
8DF2 5D               (       RRLOGD.ASM):01041                TSTB                  WHICH FLAVOR??
8DF3 2704             (       RRLOGD.ASM):01042                BEQ    DCOL7          EVEN FLAVOR
8DF5 8A80             (       RRLOGD.ASM):01043                ORA   #$80           ODD FLAVOR...SUPRESS HIGH
8DF7 2002             (       RRLOGD.ASM):01044                BRA    DCOL8
8DF9 8A40             (       RRLOGD.ASM):01045         DCOL7  ORA   #$40           EVEN FLAVOR...SUPRESS LOW
8DFB B7CA00           (       RRLOGD.ASM):01046         DCOL8  STA    CONTRL         DONE!
8DFE 3503             (       RRLOGD.ASM):01047                PULS   CC,A
8E00 2094             (       RRLOGD.ASM):01048                BRA    DOCOL2         GET THE NEXT BYTE
                      (       RRLOGD.ASM):01049         
8E02 9EDD             (       RRLOGD.ASM):01050         CEND   LDX    LOGX           RESTORE START X
8E04 5D               (       RRLOGD.ASM):01051                TSTB                  EVEN FLAVOR??
8E05 2706             (       RRLOGD.ASM):01052                BEQ    CEND1          YEP
8E07 C6FF             (       RRLOGD.ASM):01053                LDB    #$FF           MAKE NON-ZERO FLAVOR FF IN CASE
8E09 30890100         (       RRLOGD.ASM):01054                LEAX   $100,X         MOVE OVER 1
8E0D 53               (       RRLOGD.ASM):01055         CEND1  COMB                  CHANGE FLAVOR
8E0E 39               (       RRLOGD.ASM):01056                RTS                   AND RETURN
                      (asm/src/RRLOG.ASM):00580         
                      (asm/src/RRLOG.ASM):00581                END
