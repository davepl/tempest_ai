                      (sm/src/RRTEXT.ASM):00254         *****
                      (sm/src/RRTEXT.ASM):00255         *      STRING PROCESSING
                      (sm/src/RRTEXT.ASM):00256         *****
                      (sm/src/RRTEXT.ASM):00257         
                      (sm/src/RRTEXT.ASM):00258         *      CONTROL CHARACTERS :           
                      (sm/src/RRTEXT.ASM):00259         
                      (sm/src/RRTEXT.ASM):00260         *             NEWLINE - $1  WORTHLESS...DOES NOTHING                   .
                      (sm/src/RRTEXT.ASM):00261         
                      (sm/src/RRTEXT.ASM):00262         *              RETURN - $2  SAME AS NEWLINE                           
                      (sm/src/RRTEXT.ASM):00263         
                      (sm/src/RRTEXT.ASM):00264         *           LINE FEED - $3  SAME AS NEWLINE                
                      (sm/src/RRTEXT.ASM):00265         
                      (sm/src/RRTEXT.ASM):00266         *           SET COLOR - $4  THIS WILL CAUSE THE PRINTING COLOR TO BE
                      (sm/src/RRTEXT.ASM):00267         *                      CHANGED TO THE BYTE FOLLOWING THIS
                      (sm/src/RRTEXT.ASM):00268         
                      (sm/src/RRTEXT.ASM):00269         *        HYPER CURSOR - $5  THIS WILL SET THE CURSOR TO THE -THREE-
                      (sm/src/RRTEXT.ASM):00270         *                      BYTE IMMEDIATE POSITION (CURSOR,FLAVOR) (RELATIVE)
                      (sm/src/RRTEXT.ASM):00271         
                      (sm/src/RRTEXT.ASM):00272         *     SET LEFT MARGIN - $6  THIS WILL SET THE LEFT MARGIN TO THE -THREE-
                      (sm/src/RRTEXT.ASM):00273         *                      BYTE IMMEDIATE POSITION (CURSOR,FLAVOR) (RELATIVE)
                      (sm/src/RRTEXT.ASM):00274         
                      (sm/src/RRTEXT.ASM):00275         *      SET LARGE FONT - $7   THIS WILL SET NEW FONT HEIGHT TO SEVEN PIXEL.
                      (sm/src/RRTEXT.ASM):00276         
                      (sm/src/RRTEXT.ASM):00277         *      SET SMALL FONT - $8   THIS WILL SET NEW FONT HEIGHT TO FIVE PIXEL.
                      (sm/src/RRTEXT.ASM):00278         
                      (sm/src/RRTEXT.ASM):00279         *  LEAD ZERO BLANK ON - $9   
                      (sm/src/RRTEXT.ASM):00280         
                      (sm/src/RRTEXT.ASM):00281         * LEAD ZERO BLANK OFF - $A  
                      (sm/src/RRTEXT.ASM):00282         
                      (sm/src/RRTEXT.ASM):00283         * 4 DIGIT NUMBER IMM. - $B   FOLLOWED BY TWO BYTE NUMBER TO BE PRINTED
                      (sm/src/RRTEXT.ASM):00284         
                      (sm/src/RRTEXT.ASM):00285         * 4 DIGIT NUMBER IND. - $C   4 DIGIT NUMBER STORED AT TWO BYTE SUPPLIED ADDR
                      (sm/src/RRTEXT.ASM):00286         
                      (sm/src/RRTEXT.ASM):00287         * 2 DIGIT NUMBER IND. - $D   2 DIGIT NUMBER STORED IMMEDIATELY
                      (sm/src/RRTEXT.ASM):00288         
                      (sm/src/RRTEXT.ASM):00289         * 2 DIGIT NUMBER IND. - $E   4 DIGIT ADDRESS OF 2 DIGIT NUMBER STORED
                      (sm/src/RRTEXT.ASM):00290         
                      (sm/src/RRTEXT.ASM):00291         *          SUBROUTINE - $F   INVOKE A NEW PHRASE..2 BYTE ADDRESS IMMEDIATE
                      (sm/src/RRTEXT.ASM):00292         
                      (sm/src/RRTEXT.ASM):00293         * 2 DIGIT NUMBER IN B - $10  PRINT THE 2 DIGIT NUMBER CONTAINED IN B.
                      (sm/src/RRTEXT.ASM):00294         
                      (sm/src/RRTEXT.ASM):00295         * 4 DIGIT NUMBER IN Y - $11  PRINT THE 4 DIGIT NUMBER CONTAINED IN Y.
                      (sm/src/RRTEXT.ASM):00296         
                      (sm/src/RRTEXT.ASM):00297         *              CURSAB - $12  SET CURSOR AND FLAVOR TO THE IMMEDIATE OPERAND
                      (sm/src/RRTEXT.ASM):00298         
                      (sm/src/RRTEXT.ASM):00299         *  SET COLOR INDIRECT - $13  2 BYTE IMMEDIATE POINTS AT NEW COLOR
                      (sm/src/RRTEXT.ASM):00300         
                      (sm/src/RRTEXT.ASM):00301         *     CALL SUB, COND. - $14  CALL SUBROUTINE (2 BYTE IMM) IF COCKTAIL.
                      (sm/src/RRTEXT.ASM):00302         
                      (sm/src/RRTEXT.ASM):00303         *              SBLANK - $15  LEAD ZERO BLANK WITH SPACING FOR BLANKS
                      (sm/src/RRTEXT.ASM):00304         
                      (sm/src/RRTEXT.ASM):00305         *              CLIPB  - $16  SET CLIP FACTOR TO WHATS PASSED IN B
                      (sm/src/RRTEXT.ASM):00306         *                       POSITIVE NUMBER CLIPS TOP [B] ROWS
                      (sm/src/RRTEXT.ASM):00307         *                       NEGATIVE NUMBER CLIPS BOTTOM -NEGB- ROWS
                      (sm/src/RRTEXT.ASM):00308         *                       ZERO KILLS CLIPPING
                      (sm/src/RRTEXT.ASM):00309         
                      (sm/src/RRTEXT.ASM):00310         *             MNEMONICS:
                      (sm/src/RRTEXT.ASM):00311         
     0001             (sm/src/RRTEXT.ASM):00312         NEWLIN EQU    1
