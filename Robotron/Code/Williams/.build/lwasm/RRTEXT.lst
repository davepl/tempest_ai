5FF4 96CF             (sm/src/RRTEXT.ASM):00072                LDA    TEXCOL         GET THE CURRENT COLOR
5FF6 B7CA01           (sm/src/RRTEXT.ASM):00073                STA    CONST          CONSTANTLY
5FF9 BFCA04           (sm/src/RRTEXT.ASM):00074                STX    DEST           CURSOR IS WHERE ITS GOING
5FFC 861A             (sm/src/RRTEXT.ASM):00075                LDA    #$1A
5FFE D6D0             (sm/src/RRTEXT.ASM):00076                LDB    TXFLAV         CHECK OUT FLAVOR
6000 2702             (sm/src/RRTEXT.ASM):00077                BEQ    PR3502
