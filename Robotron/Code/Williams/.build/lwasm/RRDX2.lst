49F4 E02D             (asm/src/RRDX2.ASM):00554         CKK3A  SUBB   WH,Y           GET BACK TO LEFT OF OB
49F6 E72B             (asm/src/RRDX2.ASM):00555         CKK3AA STB    UL,Y           SAVE GOOD X
                      (asm/src/RRDX2.ASM):00556         
49F8 30A813           (asm/src/RRDX2.ASM):00557         CKK3B  LEAX   DATA,Y         POINT AT FIRST ITEM 
49FB E62E             (asm/src/RRDX2.ASM):00558                LDB    WH+1,Y         GET HEIGHT
49FD D0C2             (asm/src/RRDX2.ASM):00559                SUBB   HITE           FIND NUMBER WE WILL SKIP    
49FF 58               (asm/src/RRDX2.ASM):00560                ASLB                  POINTERS ARE 2 BYTES
4A00 3A               (asm/src/RRDX2.ASM):00561                ABX                   WE NOW POINT AT FIRST ONE WE WILL USE
                      (asm/src/RRDX2.ASM):00562         
                      (asm/src/RRDX2.ASM):00563         *
                      (asm/src/RRDX2.ASM):00564         *      TIME FOR THE BUTT CLIP
                      (asm/src/RRDX2.ASM):00565         *
                      (asm/src/RRDX2.ASM):00566         
4A01 96C2             (asm/src/RRDX2.ASM):00567                LDA    HITE           GET HEIGHT
4A03 4A               (asm/src/RRDX2.ASM):00568                DECA
4A04 D6BB             (asm/src/RRDX2.ASM):00569                LDB    YSIZE          FIND FILL DEFLECTION
4A06 3D               (asm/src/RRDX2.ASM):00570                MUL
4A07 EB2C             (asm/src/RRDX2.ASM):00571                ADDB   UL+1,Y         ADD FIRST POINT
4A09 8900             (asm/src/RRDX2.ASM):00572                ADCA   #0             FIND FULL DEFLECTION
4A0B 270A             (asm/src/RRDX2.ASM):00573                BEQ    CHK4           AOK
4A0D 0AC2             (asm/src/RRDX2.ASM):00574         CHK5   DEC    HITE           1 LESS
4A0F 2748             (asm/src/RRDX2.ASM):00575                BEQ    KLJMP          EXIT IMMEDIATELY ON TOTAL CLIP
4A11 D0BB             (asm/src/RRDX2.ASM):00576                SUBB   YSIZE          1 LESS DOWNWARD
4A13 8200             (asm/src/RRDX2.ASM):00577                SBCA   #0
4A15 26F6             (asm/src/RRDX2.ASM):00578                BNE    CHK5
4A17 C1EA             (asm/src/RRDX2.ASM):00579         CHK4   CMPB   #YMAX
4A19 24F2             (asm/src/RRDX2.ASM):00580                BHS    CHK5
                      (asm/src/RRDX2.ASM):00581         
4A1B 96C2             (asm/src/RRDX2.ASM):00582                LDA    HITE           GET HITE BACK
4A1D 4A               (asm/src/RRDX2.ASM):00583                DECA                  FIRSTIES DON'T COUNT
4A1E D6BA             (asm/src/RRDX2.ASM):00584                LDB    XSIZE          GET X SIZE
4A20 2B19             (asm/src/RRDX2.ASM):00585                BMI    XNT            NEGATIVE SLOPE
                      (asm/src/RRDX2.ASM):00586         
4A22 3D               (asm/src/RRDX2.ASM):00587                MUL                   DEFLECTION OF LAST GUY
4A23 EB2D             (asm/src/RRDX2.ASM):00588                ADDB   WH,Y           ADD WIDTH
4A25 EB2B             (asm/src/RRDX2.ASM):00589                ADDB   UL,Y           ADD STARTING X
4A27 8900             (asm/src/RRDX2.ASM):00590                ADCA   #0             PROP IT
4A29 270A             (asm/src/RRDX2.ASM):00591                BEQ    NCK4           NOT HUGE
4A2B 0AC2             (asm/src/RRDX2.ASM):00592         NCK5   DEC    HITE           TAKE 1 AWAY
4A2D 272A             (asm/src/RRDX2.ASM):00593                BEQ    KLJMP          TOTAL CLIP...BYE
4A2F D0BA             (asm/src/RRDX2.ASM):00594                SUBB   XSIZE          TRY AND BRING DOWN TO SIZE
4A31 8200             (asm/src/RRDX2.ASM):00595                SBCA   #0
4A33 26F6             (asm/src/RRDX2.ASM):00596                BNE    NCK5
4A35 C18F             (asm/src/RRDX2.ASM):00597         NCK4   CMPB   #XMAX
4A37 22F2             (asm/src/RRDX2.ASM):00598                BHI    NCK5           EQUAL IS OK
4A39 201A             (asm/src/RRDX2.ASM):00599                BRA    NCK6
                      (asm/src/RRDX2.ASM):00600         
4A3B 50               (asm/src/RRDX2.ASM):00601         XNT    NEGB                  MAKE 
4A3C 3D               (asm/src/RRDX2.ASM):00602                MUL
4A3D DDC3             (asm/src/RRDX2.ASM):00603                STD    TEMP1          SAVE OFFSET
                      (asm/src/RRDX2.ASM):00604         
4A3F E62B             (asm/src/RRDX2.ASM):00605                LDB    UL,Y           GET UPPER LEFT
4A41 4F               (asm/src/RRDX2.ASM):00606                CLRA
                      (asm/src/RRDX2.ASM):00607         
4A42 93C3             (asm/src/RRDX2.ASM):00608                SUBD   TEMP1          REMOVE OFFSET
4A44 4D               (asm/src/RRDX2.ASM):00609                TSTA
                      (asm/src/RRDX2.ASM):00610         
4A45 270A             (asm/src/RRDX2.ASM):00611                BEQ    NNCK4          NOT WAY TOO SMALL
                      (asm/src/RRDX2.ASM):00612         
4A47 0AC2             (asm/src/RRDX2.ASM):00613         NNCK5  DEC    HITE           1 LESS
4A49 270E             (asm/src/RRDX2.ASM):00614                BEQ    KLJMP
4A4B D0BA             (asm/src/RRDX2.ASM):00615                SUBB   XSIZE          ADDING NEG MOVES US POSITVE
4A4D 82FF             (asm/src/RRDX2.ASM):00616                SBCA   #$FF           SUB SIGN EXT
4A4F 26F6             (asm/src/RRDX2.ASM):00617                BNE    NNCK5          KEEP GOING
                      (asm/src/RRDX2.ASM):00618         
4A51 C107             (asm/src/RRDX2.ASM):00619         NNCK4  CMPB   #XMIN
4A53 23F2             (asm/src/RRDX2.ASM):00620                BLS    NNCK5          KEEP GOING
                      (asm/src/RRDX2.ASM):00621         
                      (asm/src/RRDX2.ASM):00622         *      FIND "LOOP" ENTRY
                      (asm/src/RRDX2.ASM):00623         
4A55 96C2             (asm/src/RRDX2.ASM):00624         NCK6   LDA    HITE           GET HEIGHT
4A57 2603             (asm/src/RRDX2.ASM):00625                BNE    NOKILE
4A59 7E4909           (asm/src/RRDX2.ASM):00626         KLJMP  JMP    KILEXP         NO HEIGHT
                      (asm/src/RRDX2.ASM):00627         
4A5C A7A811           (asm/src/RRDX2.ASM):00628         NOKILE STA    YHITE,Y        SAVE FOR ERASE
4A5F 8010             (asm/src/RRDX2.ASM):00629                SUBA   #16            16 = 0 OFFSET, 0 = 16 OFFSET
4A61 40               (asm/src/RRDX2.ASM):00630                NEGA
4A62 C60D             (asm/src/RRDX2.ASM):00631                LDB    #BSSIZE        SIZE OF ITERATION
4A64 3D               (asm/src/RRDX2.ASM):00632                MUL
4A65 C3478C           (asm/src/RRDX2.ASM):00633                ADDD   #BSLOOP        BEGINNING
4A68 3426             (asm/src/RRDX2.ASM):00634                PSHS   D,Y            SETUP STACK AS FOLLOWS:    
                      (asm/src/RRDX2.ASM):00635         
                      (asm/src/RRDX2.ASM):00636         *      PTR     ->   D = JUMP ADDRESS
                      (asm/src/RRDX2.ASM):00637         *                   Y = PUSHED TO SAVE FOR RTS
                      (asm/src/RRDX2.ASM):00638         *                   <RETURN ADDRESS>
                      (asm/src/RRDX2.ASM):00639         
                      (asm/src/RRDX2.ASM):00640         *                   PULS   Y,PC     AT END OF LOOP CAUSES PROPER RETURN
                      (asm/src/RRDX2.ASM):00641         
