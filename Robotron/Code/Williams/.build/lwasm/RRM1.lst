5A0B 8E59D0           (              NAP):00002                LDX #PCSUB WAKEUP ADDR
5A0E 7ED066           (              NAP):00003                JMP    SLEEP  
                      (wasm/src/RRM1.ASM):00227         
                      (wasm/src/RRM1.ASM):00228         *      MARQ - DRAW A LINKY MARQUIS.  PASS UPPER LEFT IN X.
                      (wasm/src/RRM1.ASM):00229         *      PASS LOWER RIGHT IN Y.  
                      (wasm/src/RRM1.ASM):00230         *      RANGES ARE INCLUSIVE.  LOWER-UPPER MUST BE EVEN (ODD INCLUSIVE)
                      (wasm/src/RRM1.ASM):00231         *      A CONTAINS THE HIGH AND LOW FLAVOR COLORS (<OUTER><INNER>)
                      (wasm/src/RRM1.ASM):00232         
5A11 3476             (wasm/src/RRM1.ASM):00233         MARQ   PSHS   X,Y,D,U
5A13 84F0             (wasm/src/RRM1.ASM):00234                ANDA   #$F0
5A15 97CC             (wasm/src/RRM1.ASM):00235                STA    HFLAV    SAVE FLAVOR COLORS
5A17 A6E4             (wasm/src/RRM1.ASM):00236                LDA    ,S
5A19 840F             (wasm/src/RRM1.ASM):00237                ANDA   #$0F
5A1B 97CD             (wasm/src/RRM1.ASM):00238                STA    LFLAV
5A1D 1F10             (wasm/src/RRM1.ASM):00239                TFR    X,D
5A1F 97CA             (wasm/src/RRM1.ASM):00240                STA    LEFT
5A21 D7C8             (wasm/src/RRM1.ASM):00241                STB    UPPER
5A23 1F20             (wasm/src/RRM1.ASM):00242                TFR    Y,D
5A25 97CB             (wasm/src/RRM1.ASM):00243                STA    RIGHT
5A27 D7C9             (wasm/src/RRM1.ASM):00244                STB    LOWER
5A29 D0C8             (wasm/src/RRM1.ASM):00245                SUBB   UPPER          LOWER-UPPER ODD???
5A2B 56               (wasm/src/RRM1.ASM):00246                RORB                  CHECK
5A2C 2402             (wasm/src/RRM1.ASM):00247                BCC    MARQ1          NOPE
5A2E 0AC9             (wasm/src/RRM1.ASM):00248                DEC    LOWER          NOT THAT LOW...OK?
                      (wasm/src/RRM1.ASM):00249         
5A30 BD5AC3           (wasm/src/RRM1.ASM):00250         MARQ1  JSR    GHIGH          GET HIGH DUPED  BYTE IN B 
5A33 96C8             (wasm/src/RRM1.ASM):00251                LDA    UPPER          GET THE UPPER 
5A35 BD5A89           (wasm/src/RRM1.ASM):00252                JSR    HHIGH          HIGH PART OF TOP DMASIZONTAL LINE
5A38 4C               (wasm/src/RRM1.ASM):00253                INCA
5A39 BD5ACC           (wasm/src/RRM1.ASM):00254                JSR    GLOW
5A3C 8D6C             (wasm/src/RRM1.ASM):00255                BSR    HLOW           LOW PART
                      (wasm/src/RRM1.ASM):00256         *
5A3E 96C9             (wasm/src/RRM1.ASM):00257                LDA    LOWER
5A40 BD5AC3           (wasm/src/RRM1.ASM):00258                JSR    GHIGH
5A43 8D44             (wasm/src/RRM1.ASM):00259                BSR    HHIGH          1 LESS FOR GEN PURP
5A45 4A               (wasm/src/RRM1.ASM):00260                DECA
5A46 BD5ACC           (wasm/src/RRM1.ASM):00261                JSR    GLOW
5A49 8D5F             (wasm/src/RRM1.ASM):00262                BSR    HLOW 
                      (wasm/src/RRM1.ASM):00263         *
5A4B 96CA             (wasm/src/RRM1.ASM):00264                LDA    LEFT           LEFT BYTE
5A4D BD5AD5           (wasm/src/RRM1.ASM):00265                JSR    GNORM
5A50 8D09             (wasm/src/RRM1.ASM):00266                BSR    VHIGH          HIGH FLAVOR STUFF IN A VERT LINE
                      (wasm/src/RRM1.ASM):00267         *
5A52 96CB             (wasm/src/RRM1.ASM):00268                LDA    RIGHT
5A54 BD5ADA           (wasm/src/RRM1.ASM):00269                JSR    GFLIP
5A57 8D02             (wasm/src/RRM1.ASM):00270                BSR    VHIGH
                      (wasm/src/RRM1.ASM):00271         
5A59 35F6             (wasm/src/RRM1.ASM):00272         MAR11  PULS   U,D,X,Y,PC
                      (wasm/src/RRM1.ASM):00273         
                      (wasm/src/RRM1.ASM):00274         *      VHIGH - PLOT VERTICAL LINE FROM [UPPER TO LOWER]
                      (wasm/src/RRM1.ASM):00275         *      CONSISTING OF EVERY OTHER BYTE GETTING THE HIGH NIBBLE COLOR
                      (wasm/src/RRM1.ASM):00276         *      A HAS THE X TO USE
                      (wasm/src/RRM1.ASM):00277         
5A5B 3417             (wasm/src/RRM1.ASM):00278         VHIGH  PSHS   D,X,CC
5A5D 8D1C             (wasm/src/RRM1.ASM):00279                BSR    SETUPV   SETUP X,B
5A5F 1A10             (wasm/src/RRM1.ASM):00280                SEI
5A61 B7CA01           (wasm/src/RRM1.ASM):00281                STA    DMACON    STORE CONSTANT
5A64 8605             (wasm/src/RRM1.ASM):00282                LDA    #5       1 WIDE, B HIGH
5A66 C804             (wasm/src/RRM1.ASM):00283                EORB   #4
5A68 FDCA06           (wasm/src/RRM1.ASM):00284                STD    DMASIZ
5A6B CC0000           (wasm/src/RRM1.ASM):00285                LDD    #0
5A6E FDCA02           (wasm/src/RRM1.ASM):00286                STD    DMAORG     FROM NOWHERE
5A71 BFCA04           (wasm/src/RRM1.ASM):00287                STX    DMADES     DESTINATION PEGGED
5A74 8612             (wasm/src/RRM1.ASM):00288                LDA    #$12     WRITE THE DMACONANT LINES
5A76 B7CA00           (wasm/src/RRM1.ASM):00289                STA    DMACTL
5A79 3597             (wasm/src/RRM1.ASM):00290                PULS   CC,D,X,PC
                      (wasm/src/RRM1.ASM):00291         
5A7B 3404             (wasm/src/RRM1.ASM):00292         SETUPV PSHS   B
5A7D D6C8             (wasm/src/RRM1.ASM):00293                LDB    UPPER    GET UPPER Y
5A7F 5C               (wasm/src/RRM1.ASM):00294                INCB            START 1 AFTER
5A80 1F01             (wasm/src/RRM1.ASM):00295                TFR    D,X      THIS IS PONTER
5A82 D6C9             (wasm/src/RRM1.ASM):00296                LDB    LOWER
5A84 D0C8             (wasm/src/RRM1.ASM):00297                SUBB   UPPER    THIS IS GUARANTEED EVEN
5A86 5A               (wasm/src/RRM1.ASM):00298                DECB            EXCLUSIVE PLEASE
5A87 3582             (wasm/src/RRM1.ASM):00299                PULS   A,PC
                      (wasm/src/RRM1.ASM):00300         
                      (wasm/src/RRM1.ASM):00301         *      HHIGH - THIS ROUTINE PLOTS HIGH COLOR IN THE HIGH HALF OF
                      (wasm/src/RRM1.ASM):00302         *      CONSECUTIVE DMASIZONTAL PIXELS GOING FROM 
                      (wasm/src/RRM1.ASM):00303         *      [LEFT TO RIGHT] AT THE HEIGHT GIVEN IN REGISTER A.
                      (wasm/src/RRM1.ASM):00304         
5A89 3417             (wasm/src/RRM1.ASM):00305         HHIGH  PSHS   X,D,CC
5A8B 8D28             (wasm/src/RRM1.ASM):00306                BSR    SETUPH   SETUP COUNT IN B, X POINTS AT FIRST BYTE
5A8D 5C               (wasm/src/RRM1.ASM):00307                INCB            ADD 1 TO MAKE IT INCLUSIVE
5A8E 1A10             (wasm/src/RRM1.ASM):00308         HHIGH1 SEI
5A90 B7CA01           (wasm/src/RRM1.ASM):00309                STA    DMACON    STORE THE CONSTANT
5A93 C804             (wasm/src/RRM1.ASM):00310                EORB   #4
5A95 F7CA06           (wasm/src/RRM1.ASM):00311                STB    DMASIZ
5A98 8605             (wasm/src/RRM1.ASM):00312                LDA    #5
5A9A B7CA07           (wasm/src/RRM1.ASM):00313                STA    DMASIZ+1  1 HIGH
5A9D FDCA02           (wasm/src/RRM1.ASM):00314                STD    DMAORG     GOOD ORIGINATION
5AA0 BFCA04           (wasm/src/RRM1.ASM):00315                STX    DMADES
5AA3 8612             (wasm/src/RRM1.ASM):00316                LDA    #$12
5AA5 B7CA00           (wasm/src/RRM1.ASM):00317                STA    DMACTL
5AA8 3597             (wasm/src/RRM1.ASM):00318                PULS   X,D,PC,CC
                      (wasm/src/RRM1.ASM):00319         
5AAA 3417             (wasm/src/RRM1.ASM):00320         HLOW   PSHS   X,D,CC
5AAC 8D07             (wasm/src/RRM1.ASM):00321                BSR    SETUPH   SETUP
5AAE 5A               (wasm/src/RRM1.ASM):00322                DECB            EXCLUSIVE
5AAF 30890100         (wasm/src/RRM1.ASM):00323                LEAX   $100,X   MOVE OVER 1
5AB3 20D9             (wasm/src/RRM1.ASM):00324                BRA    HHIGH1   AND GO
                      (wasm/src/RRM1.ASM):00325         
5AB5 3404             (wasm/src/RRM1.ASM):00326         SETUPH PSHS   B        SAVE COLOR
5AB7 1F89             (wasm/src/RRM1.ASM):00327                TFR    A,B      MOVE Y OVER
5AB9 96CA             (wasm/src/RRM1.ASM):00328                LDA    LEFT     GET LEFT X
5ABB 1F01             (wasm/src/RRM1.ASM):00329                TFR    D,X      MAKE POINTER
5ABD D6CB             (wasm/src/RRM1.ASM):00330                LDB    RIGHT
5ABF D0CA             (wasm/src/RRM1.ASM):00331                SUBB   LEFT     FIND DIFFERENCE (EXCLUSIVE
5AC1 3582             (wasm/src/RRM1.ASM):00332                PULS   A,PC     AND RETURN
                      (wasm/src/RRM1.ASM):00333         
5AC3 D6CC             (wasm/src/RRM1.ASM):00334         GHIGH  LDB    HFLAV    GET HIGH FLAVOR
5AC5 54               (wasm/src/RRM1.ASM):00335                LSRB
5AC6 54               (wasm/src/RRM1.ASM):00336                LSRB
5AC7 54               (wasm/src/RRM1.ASM):00337                LSRB
5AC8 54               (wasm/src/RRM1.ASM):00338                LSRB
5AC9 DACC             (wasm/src/RRM1.ASM):00339                ORB   HFLAV    HIGH FLAVOR IN BOTH
5ACB 39               (wasm/src/RRM1.ASM):00340                RTS
                      (wasm/src/RRM1.ASM):00341         
5ACC D6CD             (wasm/src/RRM1.ASM):00342         GLOW   LDB    LFLAV
5ACE 58               (wasm/src/RRM1.ASM):00343                ASLB
5ACF 58               (wasm/src/RRM1.ASM):00344                ASLB
5AD0 58               (wasm/src/RRM1.ASM):00345                ASLB
5AD1 58               (wasm/src/RRM1.ASM):00346                ASLB
5AD2 DACD             (wasm/src/RRM1.ASM):00347                ORB   LFLAV
5AD4 39               (wasm/src/RRM1.ASM):00348                RTS
                      (wasm/src/RRM1.ASM):00349         
5AD5 D6CC             (wasm/src/RRM1.ASM):00350         GNORM  LDB    HFLAV
5AD7 DACD             (wasm/src/RRM1.ASM):00351                ORB   LFLAV
5AD9 39               (wasm/src/RRM1.ASM):00352                RTS
                      (wasm/src/RRM1.ASM):00353         
5ADA D6CC             (wasm/src/RRM1.ASM):00354         GFLIP  LDB    HFLAV
5ADC 54               (wasm/src/RRM1.ASM):00355                LSRB
5ADD 54               (wasm/src/RRM1.ASM):00356                LSRB
5ADE 54               (wasm/src/RRM1.ASM):00357                LSRB
5ADF 54               (wasm/src/RRM1.ASM):00358                LSRB
5AE0 3404             (wasm/src/RRM1.ASM):00359                PSHS   B
5AE2 D6CD             (wasm/src/RRM1.ASM):00360                LDB    LFLAV
5AE4 58               (wasm/src/RRM1.ASM):00361                ASLB
5AE5 58               (wasm/src/RRM1.ASM):00362                ASLB
5AE6 58               (wasm/src/RRM1.ASM):00363                ASLB
5AE7 58               (wasm/src/RRM1.ASM):00364                ASLB
5AE8 EAE0             (wasm/src/RRM1.ASM):00365                ORB   ,S+
5AEA 39               (wasm/src/RRM1.ASM):00366                RTS
                      (wasm/src/RRM1.ASM):00367         
                      (wasm/src/RRM1.ASM):00368                END
